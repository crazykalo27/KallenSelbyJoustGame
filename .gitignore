# Gradle build artifacts
.gradle/
build/
*/build/
bin/
*/bin/

# GWT specific
html/build/
html/war/
html/gwt-unitCache/
html/war/WEB-INF/
.gwt/
gwt-unitCache/
**/gwt-unitCache/
**/symbolMaps/
**/compile-report/

# IDE specific
.idea/
*.iml
.settings/
.classpath
.project

# Logs and crash reports
hs_err_pid*
*.log

# Build artifacts
target/
out/
dist/

# Large binary files
*.jar
*.war
*.zip
*.tar.gz
*.rar

# Allow Gradle wrapper JAR (required for CI)
!gradle/wrapper/gradle-wrapper.jar

# Docs build artefacts we *don't* need:
docs/WEB-INF/
docs/**/symbolMaps/
docs/**/compile-report/

# ----- General large binary formats we don't want in git -----
*.wav
*.psd
*.mp4
*.zip
# Track the above with Git-LFS instead if ever needed.
