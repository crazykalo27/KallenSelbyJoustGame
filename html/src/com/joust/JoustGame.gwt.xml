<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Google Inc.//DTD Google Web Toolkit 2.8.2//EN"
    "http://www.gwtproject.org/doctype/2.8.2/gwt-module.dtd">
<module rename-to="html">

    <!-- Core GWT tools -->
    <inherits name="com.google.gwt.user.User" />

    <!-- ✅ Required LibGDX GWT backends (no preloader, just runtime support) -->
    <inherits name="com.badlogic.gdx.backends.gdx_backends_gwt" />
    <inherits name="com.badlogic.gdx.physics.box2d.box2d-gwt" />

    <!-- Client source -->
    <source path="" />
    <source path="client" />
    <source path="client/assets" />

    <!-- Asset path configuration -->
    <set-configuration-property name="gdx.assetpath" value="assets" />

    <!-- Your entry point -->
    <entry-point class="com.joust.client.HtmlLauncher" />

    <!-- Optional: Narrow user agents for faster compilation -->
    <set-property name="user.agent" value="safari,gecko1_8" />
    <collapse-property name="user.agent" values="*" />
</module>
